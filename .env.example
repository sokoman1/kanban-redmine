# Этот файл только для примера
# Скопируйте в .env и настройте по необходимости

# Прокси для разработки (обход CORS)
# Укажите URL вашего Redmine — запросы будут идти через localhost, без CORS
# В форме входа введите тот же URL, что и здесь
VITE_REDMINE_PROXY_TARGET=http://192.168.15.22:3000

# Порт dev-сервера (по умолчанию 5173, чтобы не конфликтовать с Redmine на 3000)
# VITE_DEV_PORT=5173

# Примеры для будущих версий:
# VITE_REDMINE_BASE_URL=https://redmine.example.com
# VITE_DEFAULT_PROJECT_ID=1
