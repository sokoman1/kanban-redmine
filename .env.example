# This file is for reference only
# Copy to .env and configure as needed

# Proxy for development (CORS bypass)
# Set your Redmine URL — requests will go through localhost, no CORS
# On the login form, enter the same URL as here
VITE_REDMINE_PROXY_TARGET=http://192.168.15.22:3000

# Dev server port (default 5173 to avoid conflict with Redmine on 3000)
# VITE_DEV_PORT=5173

# Examples for future versions:
# VITE_REDMINE_BASE_URL=https://redmine.example.com
# VITE_DEFAULT_PROJECT_ID=1
